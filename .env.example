# ╔════════════════════════════════════════════════════════════════════╗
# ║                   MemeBot 3 – DATA ACQUISITION (.env)              ║
# ╚════════════════════════════════════════════════════════════════════╝

# ───────── Modo / Logging / Zona horaria ─────────
DRY_RUN=1                     # 1 = paper trading (recom. para adquisición)
LOG_LEVEL=DEBUG               # o INFO si prefieres menos ruido
LOCAL_TZ=Europe/Madrid

# ───────── Rutas (deja vacías para defaults relativos ./data, ./logs, ./ml) ─────────
FEATURES_DIR=
LOG_PATH=
MODEL_PATH=ml/model.pkl

# ───────── Base de datos ─────────
# (puede ser ruta absoluta o relativa a /data/)
SQLITE_DB=data/memebotdatabase.db

# ───────── Wallet / listas / RPC (sin claves en data acquisition) ─────────
SOL_PRIVATE_KEY=your-wallet-private-key
SOL_PUBLIC_KEY=your-wallet-public-key
SOL_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-api-key
RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-api-key

# ───────── URLs base ─────────
DEX_API_BASE=https://api.dexscreener.com
DEXSCREENER_API=https://api.dexscreener.com
PUMPFUN_API_BASE=
RUGCHECK_API_BASE=https://api.rugcheck.xyz/v1
HELIUS_API_BASE=https://api.helius.xyz
HELIUS_REST_BASE=https://api.helius.xyz
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-api-key
GMGN_API_BASE=https://api.gmgn.ai
GECKO_API_URL=https://api.geckoterminal.com/api/v2

# ───────── API keys ─────────
BITQUERY_TOKEN=your-bitquery-token
RUGCHECK_API_KEY=your-rugcheck-api-key
GMGN_API_KEY=your-gmgn-api-key
HELIUS_API_KEY=your-helius-api-key
BIRDEYE_API_KEY=your-birdeye-api-key

# (Opcional) Credenciales OAuth Bitquery, si usas otro flujo
BQ_CLIENT_ID=your-bitquery-client-id
BQ_CLIENT_SECRET=your-bitquery-client-secret

# ╔════════════════════════════════════════════════════════════════════╗
# ║                       Descubrimiento & Timings                     ║
# ╚════════════════════════════════════════════════════════════════════╝
SLEEP_SECONDS=4               # sleep principal del loop
DISCOVERY_INTERVAL=60         # cada cuánto refrescar descubrimiento
VALIDATION_BATCH_SIZE=18      # cuántos pares validar por ciclo
EVALUATE_TOKEN_TIMEOUT_S=120
MAX_CANDIDATES=50
MAX_QUEUE_SIZE=250
NULL_WARNING_TTL_S=300
POLICY_REJECT_DEDUP_TTL_S=900
GECKO_MIN_QUEUE_AGE_S=60
GECKO_MIN_QUEUE_ATTEMPTS=2

# Re-queues / reintentos
MAX_RETRIES=5
INCOMPLETE_RETRIES=3
MAX_INCOMPLETE_SEC=1200
QUEUE_NON_DECREMENT_REASON_PREFIXES=strategy:confirm_snapshots,live_profit_gate:

# Monitor: nº máx. de consultas “críticas” (ignoran caché negativa)
CRIT_PRICE_MAX_PER_CYCLE=8
# Ventana de bootstrap (min) tras BUY con sonda más agresiva
CRIT_BOOTSTRAP_MIN=20

# Retrain (en UTC): RETRAIN_FREQUENCY=daily|weekly ; RETRAIN_DAY solo aplica en weekly
RETRAIN_FREQUENCY=daily
RETRAIN_DAY=3
RETRAIN_HOUR=4

# ╔════════════════════════════════════════════════════════════════════╗
# ║              Monitor / Shadow-Sim                                  ║
# ╚════════════════════════════════════════════════════════════════════╝
FORCE_JUP_IN_MONITOR=true       # true = forzar siempre Jupiter en monitor, aunque compra fuese non-JUP
REAL_SHADOW_SIM=false           # true = simular posiciones shadow en modo real (dataset extra)
ML_GATE_MODE=shadow             # PR-8 canary: modela decisiones en sombra antes de permitir gate real
RESEARCH_LANE_ENABLED=true
RESEARCH_SHADOW_ENABLED=true
RESEARCH_DECISION_DEDUP_TTL_S=600
RESEARCH_SHADOW_MAX_OPEN=6
RESEARCH_SHADOW_MAX_OPEN_PER_REGIME=4
RESEARCH_SHADOW_MIN_RANK_SCORE=42
RESEARCH_SHADOW_MIN_AGE_MIN=2.0
RESEARCH_SHADOW_MIN_LIQUIDITY_USD=1000
RESEARCH_SHADOW_USE_GECKO=false
PUMPFUN_PRICE_USE_GECKO=true
RESEARCH_NEAR_MISS_SCORE_MARGIN=10
RESEARCH_NEAR_MISS_PROBA_MARGIN=0.15
RESEARCH_SCORECARD_INTERVAL_MIN=60
RESEARCH_THRESHOLD_MIN_OUTCOMES=20
RESEARCH_THRESHOLD_MIN_POSITIVES=4
RESEARCH_THRESHOLD_MIN_SELECTED=6
RESEARCH_THRESHOLD_MIN_REALIZED_SELECTED=4
RESEARCH_THRESHOLD_PRECISION_FLOOR=0.55

# ╔════════════════════════════════════════════════════════════════════╗
# ║                  Ventanas horarias (24/7 en acquisition)           ║
# ╚════════════════════════════════════════════════════════════════════╝
# Si estos quedan vacíos ⇒ 24/7 (sin gate horario)
TRADING_HOURS=
TRADING_HOURS_EXTRA=
USE_EXTRA_HOURS=false
# Bloqueos explícitos por hora (coma-separado, ej. "17,3,4-5"); vacío ⇒ no bloquea
BLOCK_HOURS=

# ╔════════════════════════════════════════════════════════════════════╗
# ║                  IA / Entrenamiento y Umbral                       ║
# ╚════════════════════════════════════════════════════════════════════╝
TRAIN_FORWARD_HOLDOUT_DAYS=3    # PR-8: hold-out forward estricto para validación temporal
TRAIN_FORWARD_HOLDOUT_PCT=0.0   # % de datos reservados como hold-out (0.0 = ignora, usar DAYS)
TRAINING_WINDOW_DAYS=28         # ventana móvil de entrenamiento (ej. últimos 28 días)
MIN_THRESHOLD_CHANGE=0.01       # cambio mínimo (en puntos porcentuales) para actualizar AI_THRESHOLD
PRECISION_AT_K_PCT=0.10
AI_THRESHOLD_FILE=data/metrics/recommended_threshold.json  # ruta del threshold dinámico recomendado
AI_THRESHOLD=0.0                # en acquisition no filtramos por IA (recoger todo)
AI_SIZING_ENABLED=false
LIVE_RANK_SCORE_FALLBACK_MIN=12.5
LIVE_RANK_SCORE_MIN_SELECTED_ROWS=20
LIVE_RANK_SCORE_MIN_AVG_PNL_PCT=3.0
BUY_SOFT_SCORE_MIN=0            # gate de compra (tarde). Aunque pase IA, no compra si el “soft score” está por debajo.
ML_MIN_DATASET_ROWS=190
ML_MIN_POSITIVES=40
ML_MIN_UNIQUE_TOKENS=190
ML_MIN_REALIZED_RETURN_ROWS=50
ML_MIN_HOLDOUT_ROWS=40
ML_MIN_HOLDOUT_POSITIVES=8
ML_MIN_NON_CONSTANT_FEATURES=12
ML_TUNE_OBJECTIVE=expected_pnl_precision_floor
ML_TUNE_PRECISION_FLOOR=0.60
ML_TUNE_MIN_SELECTED=10
ML_TUNE_MIN_REALIZED_SELECTED=5
ML_SELECTION_MIN_DELTA=0.25
ML_TRAIN_ENTRY_LANE_ALLOWLIST=pump_early_pumpswap_profit,pump_early_pumpswap_prime,pump_early_meteor_prime
ML_TRAIN_ALLOW_MISSING_ENTRY_LANE=true
ML_TRAIN_DEX_ALLOWLIST=pumpswap
ML_BOOTSTRAP_RESEARCH_SHADOW_ENABLED=true
ML_BOOTSTRAP_ONLY_WHEN_MODEL_MISSING=false
ML_BOOTSTRAP_ENTRY_LANE_ALLOWLIST=pump_early_pumpswap_profit,pump_early_pumpswap_prime,pump_early_meteor_prime,pump_early_sniper_research
ML_BOOTSTRAP_DEX_ALLOWLIST=

# ╔════════════════════════════════════════════════════════════════════╗
# ║                 Perfil de filtros – Data Acquisition               ║
# ╚════════════════════════════════════════════════════════════════════╝
MAX_AGE_DAYS=1
MIN_AGE_MIN=0.05
MIN_LIQUIDITY_USD=1000        # umbral bajo para recopilar mas muestras
MIN_VOL_USD_24H=2000          # mas permisivo para entradas tempranas
MAX_24H_VOLUME=80000000
MIN_MARKET_CAP_USD=2000
MAX_MARKET_CAP_USD=8000000
MIN_HOLDERS=0
MIN_SCORE_TOTAL=30            # filtro de descubrimiento (pruning temprano). Evita meter basura en la cola.

# DexScreener: actividad mínima reciente (si aplica)
DEXS_TXNS_5M_MIN=2

# PR-5: canario de PAPER, relajado tras corregir fetchers/edad/router
FILTER_PROFILE_BY_DISCOVERY=true
SNAPSHOT_QUALITY_FILTER_ENABLED=true
SNAPSHOT_MAX_MISSING_FIELDS=4
SNAPSHOT_REQUIRE_ACTIVITY_SIGNAL=false
SNAPSHOT_REQUIRE_SOCIAL_OR_TREND=false
SNAPSHOT_REQUIRE_RUG_SCORE=false
SNAPSHOT_ALLOWED_PRICE_SOURCES=jupiter,birdeye,dexscreener

# Perfil DEX
DEX_MIN_AGE_MIN=0.05
DEX_MIN_HOLDERS=0
DEX_MIN_LIQUIDITY_USD=1000
DEX_MIN_VOL_USD_24H=1000
DEX_MAX_MARKET_CAP_USD=250000
DEX_BUY_SOFT_SCORE_MIN=35
DEX_REQUIRE_JUPITER_FOR_BUY=true

# Perfil Pump.fun
PUMPFUN_MIN_AGE_MIN=0.05
PUMPFUN_MIN_HOLDERS=1
PUMPFUN_MIN_LIQUIDITY_USD=1000
PUMPFUN_MIN_VOL_USD_24H=1000
PUMPFUN_MAX_MARKET_CAP_USD=2000000
PUMPFUN_BUY_SOFT_SCORE_MIN=35
PUMPFUN_REQUIRE_JUPITER_FOR_BUY=true

# PR-6: sizing y exposición solo como canario en PAPER (DRY_RUN=1)
REGIME_PUMP_EARLY_MAX_AGE_MIN=30
DYNAMIC_SIZING_ENABLED=true
SIZE_MIN_MULTIPLIER=0.10
