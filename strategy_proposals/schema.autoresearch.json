{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MemeBot3 AutoResearch Candidate Policy",
  "type": "object",
  "required": [
    "proposal_id",
    "created_at_utc",
    "experiment_type",
    "hypothesis",
    "target_lanes",
    "changes",
    "expected_effect",
    "required_gates",
    "api_budget_sensitive",
    "live_allowed",
    "risk_notes"
  ],
  "properties": {
    "proposal_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "experiment_type": {
      "type": "string",
      "enum": ["replay", "paper_forward", "paper_replay", "paper"]
    },
    "hypothesis": {
      "type": "string",
      "minLength": 1
    },
    "target_lanes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "changes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": ["string", "number", "integer", "boolean"]
      }
    },
    "expected_effect": {
      "type": "object"
    },
    "required_gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "api_budget_sensitive": {
      "type": "boolean"
    },
    "live_allowed": {
      "const": false
    },
    "risk_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
